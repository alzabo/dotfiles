{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(go vet:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go list:*)",
      "Bash(go doc:*)",
      "Bash(go env:*)",
      "Bash(go version)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(ps:*)",
      "Bash(df:*)",
      "Bash(du:*)",
      "Bash(free:*)",
      "Bash(uname:*)",
      "Bash(date:*)",
      "Bash(just --list)",
      "Bash(just --show:*)",
      "Bash(make -n:*)"
    ]
  }
}
